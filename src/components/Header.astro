---
const links = [
  { href: "/", label: "Accueil" },
  { href: "/articles", label: "Articles" },
  { href: "/notes", label: "Notes" },
  { href: "/about", label: "À propos" },
];
---

<header class="sticky top-0 z-50 border-b border-black/5 bg-[#F6F1E8]/90 backdrop-blur">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-5">
    <a
      href="/"
      class="text-lg font-semibold tracking-tight hover:opacity-70 transition"
    >
      jnroudet
    </a>

    <ul class="flex gap-6 text-sm">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class="opacity-80 transition hover:opacity-100 hover:text-[#CB997E]"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>